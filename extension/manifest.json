{
  "manifest_version": 3,
  "name": "short.string.md",
  "version": "0.1.0",
  "description": "Shorten URLs with short.string.md — compression + Nostr aliases, optional P2P swarming",
  "permissions": [
    "storage",
    "contextMenus",
    "offscreen",
    "activeTab",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Shorten current page URL"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
